NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
ANTHROPIC_API_KEY=your-anthropic-key
RESEND_API_KEY=your-resend-key

# Audit IA Public — Hermes Agent webhook
# Public URL of the Hermes webhook (configure Traefik on the VPS to expose port 8644)
HERMES_WEBHOOK_URL=https://webhook.gralt.fr/webhooks/gralt-audit-inbound
# Shared secret used to sign payloads with HMAC-SHA256 (X-Hub-Signature-256 header)
HERMES_HMAC_SECRET=replace-with-strong-random-secret

# Base URL used to build the callback URL Hermes will POST to when the pipeline completes
NEXT_PUBLIC_GRALT_BASE_URL=https://gralt.fr

# Audit mail (Resend) — From / Reply-To / Cal.com link
AUDIT_MAIL_FROM=Raphael Marques <raphael@gralt.fr>
AUDIT_MAIL_REPLY_TO=raphael@gralt.fr
AUDIT_CAL_LINK=https://cal.com/raphael-gralt/30min
